{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "SV Subscriber",
  "version": "1.0.0",
  "identifier": "com.sv.subscriber",
  "build": {
    "frontendDist": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SV Subscriber - IEC 61850-9-2LE",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libpcap0.8", "libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "postInstallScript": "scripts/postinst.sh"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser"
      }
    }
  }
}
